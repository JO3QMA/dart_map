{
  "name": "dart-map",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fmt": "npm run format",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "npm run generate:seed && tsc -b && vite build",
    "build:watch": "vite build --watch",
    "preview": "vite preview",
    "generate:seed": "tsx scripts/generateRegionsFromGeolonia.ts",
    "dev:wrangler": "npm run build && npx wrangler dev"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "typescript-eslint": "^8.15.0",
    "prettier": "^3.4.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "jsdom": "^25.0.1",
    "vitest": "^4.1.0",
    "wrangler": "latest",
    "@tailwindcss/vite": "^4.0.0",
    "@types/geojson": "^7946.0.15",
    "@types/leaflet": "^1.9.16",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@types/node": "^25.5.0",
    "tailwindcss": "^4.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
